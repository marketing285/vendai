# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs (voz do MAX)
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=          # ID da voz escolhida no painel ElevenLabs

# Supabase (preencher após criar o projeto em supabase.com)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Notion (legado — substituído pelo NocoDB)
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=           # ID do database de tasks no Notion

# NocoDB (self-hosted)
NOCODB_URL=https://seu-nocodb.dominio.com
NOCODB_BASE_ID=               # ID da base no NocoDB (visível na URL do painel)
NOCODB_TOKEN=                 # API token gerado em Account > API Tokens

# CEO PIN (autenticação por voz no MAX)
CEO_PIN=0000

# Servidor
PORT=3000

# Meta Ads (via n8n)
# Webhook do n8n que consulta a Meta Ads API — deixe vazio para desativar
N8N_META_ADS_WEBHOOK=https://seu-n8n.com/webhook/meta-ads
